# ─────────────────────────────────────────────────────────────
# PosoKanei4Real scraper — environment variables
# Copy this file to scraper/.env and fill in your values.
# The .env file is git-ignored and never committed.
# ─────────────────────────────────────────────────────────────

# ── Firebase credentials (pick ONE of the two options below) ──

# OPTION A (recommended): paste the entire service account JSON as one line.
# Get it from: Firebase Console → Project Settings → Service Accounts →
#              Generate new private key  →  copy the JSON content here.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# OPTION B: point to a local credentials file instead.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/serviceAccount.json

# ── Scraper behaviour ──────────────────────────────────────────

# Set to "1" to run all scrapers but skip the Firestore upload (safe for testing)
DRY_RUN=0

# How many supermarket scrapers run in parallel (default: 4)
SCRAPER_WORKERS=4

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
